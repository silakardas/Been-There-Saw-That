@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Been There Saw That</title>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            height: 100%;
            background-color: #000;
            font-family: 'Archivo Black', sans-serif;
            min-width: 1200px;
            overflow-x: auto;
        }

        .hero-container {
            background-image: url('/images/Home.jpeg');
            background-repeat: no-repeat;
            background-position: center;
            background-size: cover;
            height: 100vh;
            width: 100%;
        }

        .content-overlay {
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.2);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            padding: 5vh 0;
        }

        .title {
            color: #F5E6CC;
            font-size: 8rem;
            line-height: 0.85;
            text-align: center;
            letter-spacing: -2px;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
            text-transform: uppercase;
        }

        .button-group {
            display: flex;
            width: 1000px;
            justify-content: space-between;
            margin: -2rem 0;
            z-index: 10;
        }

        .btn {
            background-color: #4A3222;
            color: #F5E6CC;
            text-decoration: none;
            padding: 25px 60px;
            border-radius: 50px;
            font-size: 1.5rem;
            transition: transform 0.3s ease, background 0.3s ease;
            display: inline-block;
            text-align: center;
            min-width: 250px;
        }

            .btn:hover {
                background-color: #5D4037;
                transform: scale(1.05);
            }

        .top-title {
            margin-top: 20px;
        }

        .bottom-title {
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <main class="hero-container">
        <div class="content-overlay">
            <h1 class="title top-title">BEEN <br> THERE</h1>
            <div class="button-group">
                <a asp-controller="Account" asp-action="Login" class="btn">GİRİŞ YAP</a>
                <a asp-controller="Account" asp-action="Register" class="btn">KAYIT OL</a>
            </div>
            <h1 class="title bottom-title">SAW <br> THAT</h1>
        </div>
    </main>
</body>
</html>